{
  "name": "nagi-bench-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "sync-outputs": "rm -rf public/outputs && mkdir -p public && cp -R ../outputs public/outputs",
    "validate": "bun scripts/validate-data.ts",
    "dev": "bun run sync-outputs && vite",
    "build": "bun run sync-outputs && bun run validate && tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@lobehub/icons-static-svg": "^1.91.0",
    "gsap": "^3.13.0",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.10",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "puppeteer-core": "^25.1.0",
    "tailwindcss": "^4.1.10",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
